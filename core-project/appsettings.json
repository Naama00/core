{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/requests_.log",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff}] | {RequestMethod} | {Controller}/{Action} | User: {Username} | Status: {StatusCode} | Duration: {Duration}ms",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 52428800,
          "retainedFileCountLimit": 10,
          "rollOnFileSizeLimit": true,
          "shared": true
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId", "WithProperty"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Authentication": {
    "Google": {
      "ClientId": "287325519250-tboottnqnn2ch029hsq8u3flgrhkql9i.apps.googleusercontent.com",
      "ClientSecret": "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"
    }
  }
}